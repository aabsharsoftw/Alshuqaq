# ===== App =====
NODE_ENV=development
PORT=3000
# Comma-separated list of allowed CORS origins, or * for all
CORS_ORIGIN=*

# ===== Database (Postgres) =====
# When running the app on the host against the docker postgres, use localhost.
# When running the app inside docker-compose, host is the service name "db".
DATABASE_URL=postgresql://rental:rental@localhost:5432/rental?schema=public

# Used by the postgres docker container (docker-compose)
POSTGRES_USER=rental
POSTGRES_PASSWORD=rental
POSTGRES_DB=rental

# ===== JWT =====
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ===== Admin seed (prisma/seed.ts) =====
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Administrator
# Where admin notification emails are sent (defaults to ADMIN_EMAIL if unset)
ADMIN_NOTIFY_EMAIL=admin@example.com

# ===== Resend (email) =====
RESEND_API_KEY=re_your_api_key
MAIL_FROM="Rental App <onboarding@resend.dev>"

# ===== ImageKit (images) =====
IMAGEKIT_PUBLIC_KEY=public_xxx
IMAGEKIT_PRIVATE_KEY=private_xxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id
# Folder where listing images are stored in ImageKit
IMAGEKIT_FOLDER=/rental-listings

# ===== LibreTranslate (en <-> ar translation) =====
# Self-hosted instance. When running the app on the host against the docker
# service, use localhost; inside docker-compose use the service name.
LIBRETRANSLATE_URL=http://localhost:5000
# Only required if your LibreTranslate instance enforces an API key.
LIBRETRANSLATE_API_KEY=
