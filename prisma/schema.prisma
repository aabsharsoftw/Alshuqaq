// Prisma schema for the rental apartment listing marketplace (middleman model).
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TENANT
  LANDLORD
  ADMIN
}

enum ListingStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Language {
  EN
  AR
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String // bcrypt hash
  name             String
  phone            String?
  role             Role      @default(TENANT)
  preferredLanguage Language @default(EN)
  // Trusted-landlord flag: once Admin approves a landlord, their future
  // listings are auto-approved (no per-listing review).
  landlordApproved Boolean   @default(false)
  listings         Listing[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Listing {
  id            String         @id @default(uuid())
  // Human-friendly public reference number, starts at 1 and increments.
  listingNumber Int            @unique @default(autoincrement())
  // Bilingual text. The landlord enters details in one language (en or ar);
  // the backend auto-fills the other via the self-hosted LibreTranslate service.
  titleEn       String
  titleAr       String
  rent          Int
  locationEn    String
  locationAr    String
  descriptionEn String
  descriptionAr String
  status        ListingStatus  @default(PENDING)
  landlord      User           @relation(fields: [landlordId], references: [id])
  landlordId    String
  images        ListingImage[]
  enquiries     Enquiry[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
  @@index([landlordId])
}

model ListingImage {
  id           String  @id @default(uuid())
  url          String
  thumbnailUrl String?
  fileId       String // ImageKit fileId, used for deletion
  listing      Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId    String
  createdAt    DateTime @default(now())

  @@index([listingId])
}

model Enquiry {
  id        String   @id @default(uuid())
  name      String
  phone     String
  email     String?
  message   String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
  createdAt DateTime @default(now())

  @@index([listingId])
}
